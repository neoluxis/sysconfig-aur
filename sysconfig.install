post_install() {
    # 提醒用户关于驱动/串口的权限问题
    echo ">>>"
    echo ">>> 提示：为了能够通过 USB 访问 TI 开发板，"
    echo ">>> 请确保您的用户已加入 uucp 用户组："
    echo ">>> # sudo usermod -aG uucp <您的用户名>"
    echo ">>>"
    
    # 刷新桌面环境图标缓存
    update-desktop-database -q
}

post_upgrade() {
    post_install
}

post_remove() {
    update-desktop-database -q
}

